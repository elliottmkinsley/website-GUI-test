# Python (added by the gui/ desktop app)
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/

# Environment files (the gui's optional .env override)
.env
.env.local
gui/.env

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage*
htmlcov/

# Build artifacts (PyInstaller + Inno Setup outputs)
build/
dist/
*.egg-info/
*.spec.bak

# Code-signing material - never commit these
*.pfx
*.p12

# Publish probe (the gui writes this to test the SMB share)
.radiant_publish_test
