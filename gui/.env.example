# Copy to .env (or simply export these in your shell) for local dev.
# These are the only env vars the GUI looks at.

# GitHub OAuth Client ID. Required.
# Create a public OAuth App at https://github.com/settings/applications/new
# - Homepage URL: any URL (e.g. https://radiant.nau.edu)
# - Authorization callback URL: any URL (Device Flow doesn't use it)
# - Tick "Enable Device Flow"
# Then paste the resulting Client ID below or hard-code it in gui/config.py.
RADIANT_GUI_GITHUB_CLIENT_ID=

# Optional: override the SMB mount path for the NAU share.
# Defaults to the per-OS path baked into gui/config.py.
# RADIANT_GUI_SMB_PATH=/Volumes/radiant.nau.edu
